    <sql>-- denormalised 

TRUNCATE TABLE [d_easyrental_dwh].[dim_cars]
INSERT INTO [d_easyrental_dwh].[dim_cars]
SELECT 
       a.license_plate,
       a.model,
       a.year,
       b.name AS category_name
FROM [easyrental_stg].[cars] a
LEFT OUTER JOIN [easyrental_stg].[car_categories] b ON a.category_id = b.id


-- mormalised


TRUNCATE TABLE [n_easyrental_dwh].[dim_cars]
INSERT INTO [n_easyrental_dwh].[dim_cars]
SELECT 
       a.license_plate,
       a.model,
       a.year,
       b.name AS category_name
FROM [easyrental_stg].[cars] a
LEFT OUTER JOIN [easyrental_stg].[car_categories] b ON a.category_id = b.id



</sql>
