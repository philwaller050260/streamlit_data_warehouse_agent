    <sql>TRUNCATE TABLE [n_easyrental_dwh].[dim_booking_dates]
DECLARE @StartDate DATE = '2020-01-01'
DECLARE @EndDate DATE = '2026-12-31'
;WITH DateSequence AS (
  SELECT @StartDate AS [date]
  UNION ALL
  SELECT DATEADD(day, 1, [date])
  FROM DateSequence
  WHERE DATEADD(day, 1, [date]) &lt;= @EndDate
)
INSERT INTO [n_easyrental_dwh].[dim_booking_dates] (date, year, quarter, month, day, weekday)
SELECT 
  [date],
  YEAR([date]) AS year,
  DATEPART(quarter, [date]) AS quarter,
  MONTH([date]) AS month,
  DAY([date]) AS day,
  FORMAT([date], 'dddd') AS weekday
FROM DateSequence
OPTION (MAXRECURSION 0)</sql>
